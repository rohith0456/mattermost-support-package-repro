# mm-repro Environment Variable Template
# ========================================
# Copy this to .env and customize for your repro.
#
# SECURITY: Generated .env files always contain LOCAL-ONLY credentials.
# NEVER use real production credentials here.
# NEVER commit .env to version control.
#
# ========================================

# ============================================================
# MATTERMOST
# ============================================================
MM_SITE_URL=http://localhost:8065
MM_PORT=8065

# Docker image settings (generated by mm-repro init)
MM_IMAGE=mattermost/mattermost-team-edition
MM_TAG=latest

# ============================================================
# DATABASE (LOCAL REPRO ONLY — not customer credentials)
# ============================================================
MM_DB_DRIVER=postgres
MM_DB_USER=mmuser
MM_DB_PASSWORD=mmuser_password_local_repro_only
MM_DB_NAME=mattermost
MM_DATASOURCE=postgres://mmuser:mmuser_password_local_repro_only@postgres:5432/mattermost?sslmode=disable

# PostgreSQL port
POSTGRES_PORT=5432

# ============================================================
# EMAIL (MailHog — captures all outbound email)
# ============================================================
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ============================================================
# OPENSEARCH (optional — enable with --with-opensearch)
# ============================================================
OPENSEARCH_PORT=9200

# ============================================================
# MINIO (optional — enable with --with-minio)
# ============================================================
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=repro_minio_user
MINIO_ROOT_PASSWORD=minio_password_local_repro_only
MINIO_BUCKET=mattermost-repro

# ============================================================
# LDAP (optional — enable with --with-ldap)
# ============================================================
LDAP_PORT=389
LDAPS_PORT=636
LDAP_DOMAIN=repro.local
LDAP_BASE_DN=dc=repro,dc=local
LDAP_ADMIN_PASSWORD=ldap_admin_local_repro_only
LDAP_BIND_USER=readonly
LDAP_BIND_PASSWORD=readonly_local_repro_only

# ============================================================
# KEYCLOAK (optional — enable with --with-saml)
# ============================================================
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_admin_local_repro_only

# ============================================================
# OBSERVABILITY (optional — enable with --with-grafana)
# ============================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_admin_local_repro_only
